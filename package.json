{
  "name": "zotero-tagnavigator",
  "type": "module",
  "version": "1.0.0",
  "description": "Advanced Tag Explorer and Quick-Tagging plugin for Zotero 7/8/9",
  "config": {
    "addonName": "Zotero TagNavigator",
    "addonID": "tagnavigator@arqueon.org",
    "addonRef": "tagnavigator",
    "addonInstance": "TagNavigator",
    "prefsPrefix": "extensions.zotero.tagnavigator"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arqueon/zotero-tagnavigator.git"
  },
  "author": "Rubén",
  "bugs": {
    "url": "https://github.com/arqueon/zotero-tagnavigator/issues"
  },
  "homepage": "https://github.com/arqueon/zotero-tagnavigator#readme",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "zotero-plugin-toolkit": "^5.1.0-beta.13"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@zotero-plugin/eslint-config": "^0.6.7",
    "chai": "^6.2.1",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.2",
    "zotero-types": "^4.1.0-beta.4"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
